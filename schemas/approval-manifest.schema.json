{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/monolith-droid/codex-maintainer-safety-kit/schemas/approval-manifest.schema.json",
  "title": "I/O Safety Kit for OSS Approval Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "operation",
    "repository",
    "requested_by",
    "reason",
    "risk_level",
    "allowed_actions",
    "targets",
    "approval"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "iosk.approval.v1"
    },
    "operation": {
      "type": "string",
      "enum": [
        "pr_review",
        "issue_triage",
        "release_checklist",
        "security_audit",
        "dependency_audit",
        "maintainer_handoff",
        "ci_failure_analysis"
      ]
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "requested_by": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "purpose"],
        "properties": {
          "type": { "type": "string" },
          "path": { "type": "string" },
          "url": { "type": "string" },
          "ref": { "type": "string" },
          "purpose": { "type": "string" }
        },
        "anyOf": [
          { "required": ["path"] },
          { "required": ["url"] },
          { "required": ["ref"] }
        ]
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "preview": { "type": "string" },
        "execute": { "type": "boolean", "const": false }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"]
        },
        "approval_id": { "type": "string" },
        "approved_by": { "type": "string" },
        "approved_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
